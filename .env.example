# ---------------------------------------------------------------------------
# Copy to .env and fill in. The .env file is never committed.
# ---------------------------------------------------------------------------

# Django
DJANGO_SECRET_KEY=change-me-in-production
DJANGO_DEBUG=False
# Comma-separated hosts, or "*" to allow all (temporary, while frontend/infra
# is being set up). Lock this down before going public.
DJANGO_ALLOWED_HOSTS=*

# CORS (frontend access)
# Leave the origin list empty and set this to True to allow all origins while
# the frontend is being set up. Replace with an explicit list later.
CORS_ALLOW_ALL_ORIGINS=True
CORS_ALLOWED_ORIGINS=

# PostgreSQL
# When POSTGRES_DB is set, Django uses PostgreSQL; otherwise it falls back to
# SQLite. In docker-compose, POSTGRES_HOST is injected as the "db" service.
POSTGRES_DB=filey
POSTGRES_USER=filey
POSTGRES_PASSWORD=change-me
# Only needed when running Django outside docker-compose (compose sets these):
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432

# Resend email delivery (notificaciones app)
RESEND_API_KEY=re_your_api_key_here
# For dev, Resend's onboarding sender only delivers to your own account email.
# For real use, verify a domain in Resend and send from it.
DEFAULT_FROM_EMAIL=onboarding@resend.dev
